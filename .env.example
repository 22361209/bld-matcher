# Copy this file to .env for local overrides.
# SECRET_KEY 必须改成随机长字符串,否则在 APP_DEBUG=0 (生产) 模式下会拒绝启动。
# 可用 `python -c "import secrets; print(secrets.token_urlsafe(48))"` 生成。
SECRET_KEY=change-this-local-secret
MAX_UPLOAD_MB=20
APP_HOST=127.0.0.1
APP_PORT=5055
APP_DEBUG=0

# Optional emergency fallback. 日常建议在网页“内部 API Key”页面生成 Key。
# /api/internal/* 始终需要 Authorization: Bearer <token>。
# INTERNAL_API_TOKEN=

# 首启时创建的管理员。空数据库启动前必须显式设置密码，否则服务拒绝启动。
# DEFAULT_ADMIN_USERNAME=007
DEFAULT_ADMIN_PASSWORD=

# Optional path overrides.
# BLD_DATA_DIR=/absolute/path/to/data
# BLD_UPLOAD_DIR=/absolute/path/to/uploads
# BLD_OUTPUT_DIR=/absolute/path/to/outputs

# Optional shipment photo label recognition.
# Works with OpenAI-compatible vision chat-completions endpoints.
# SHIPMENT_VISION_API_KEY=
# SHIPMENT_VISION_BASE_URL=https://api.openai.com/v1
# SHIPMENT_VISION_MODEL=
